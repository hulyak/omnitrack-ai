# Frontend Environment Variables for Staging
NEXT_PUBLIC_ENVIRONMENT=staging

# API Configuration
NEXT_PUBLIC_API_URL=https://api-staging.omnitrack.example.com
NEXT_PUBLIC_WS_URL=wss://ws-staging.omnitrack.example.com

# AWS Cognito Configuration
NEXT_PUBLIC_USER_POOL_ID=us-east-1_XXXXXXXXX
NEXT_PUBLIC_USER_POOL_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_AWS_REGION=us-east-1

# Feature Flags
NEXT_PUBLIC_ENABLE_AR_VISUALIZATION=true
NEXT_PUBLIC_ENABLE_VOICE_INTERFACE=true
NEXT_PUBLIC_ENABLE_MARKETPLACE=true

# Analytics (optional)
NEXT_PUBLIC_ANALYTICS_ID=

# Debug Mode
NEXT_PUBLIC_DEBUG_MODE=true
